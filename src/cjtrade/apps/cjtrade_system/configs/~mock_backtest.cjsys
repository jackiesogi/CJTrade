# Mock Broker - Backtest Mode Configuration
# High speed simulation with larger analysis window

# Trading Mode
BACKTEST_MODE=y
PLAYBACK_SPEED=60.0
BACKTEST_DURATION_DAYS=1

# System Intervals (seconds)
PRICE_MONITOR_INTERVAL=15
ANALYSIS_INTERVAL=60
LLM_REPORT_INTERVAL=50000
DISPLAY_TIME_INTERVAL=90
CHECK_FILL_INTERVAL=20

# Technical Analysis Parameters
WINDOW_SIZE=20
BB_MIN_WIDTH_PCT=0.01

# Risk Management
RISK_MAX_POSITION_PCT=0.05
