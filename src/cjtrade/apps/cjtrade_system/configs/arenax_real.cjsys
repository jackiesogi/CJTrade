# Real Mode Configuration
# ----------------------
# Warning: This configuration will be used as the default for live trading in the CJTrade System,
# unless the user explicitly specifies a custom configuration file.
# ----------------------
# 請注意：在 CJTrade System 進行實盤交易時，此設定檔將自動作為預設設定，除非使用者另外明確指定自訂設定檔。
# ----------------------
# 注意：CJTradeシステムで実取引を行う際、この設定ファイルはデフォルト設定として使用されます。ユーザーが明示
# 的にカスタム設定を指定しない限り変更されません。
# ----------------------
# 주의: CJTrade 시스템에서 실거래를 진행할 경우, 이 설정 파일은 기본 설정으로 사용됩니다.
# 사용자가 별도로 사용자 정의 설정을 명시하지 않는 한 변경되지 않습니다.
# ----------------------
# Advertencia: Esta configuración se utilizará como predeterminada para operaciones en vivo en el
# sistema CJTrade, a menos que el usuario especifique explícitamente una configuración personalizada.
# ----------------------
# Avertissement : Cette configuration sera utilisée par défaut pour le trading en direct dans le
# système CJTrade, sauf si l'utilisateur spécifie explicitement une configuration personnalisée.

# =====================================   CJTrade System Launch Mode   ======================================
# `real` mode is used for REAL (LIVE) TRADING, you must be careful to adjust these settings,
# be sure to have enough backtest and analysis before go into `real` mode, or you may risk your money!!!

# =========================================   General Configuration   =======================================
# watch list controls which stock tickers to include in the backtest (comma-separated e.g. 0050,2330,2317)
# If empty, it will use the positions in your current portfolio as the watch list for backtesting.
CJSYS_WATCH_LIST              =
CJSYS_REMOTE_HOST             = localhost
CJSYS_REMOTE_PORT             = 8888
# ===========================================================================================================


# ======================================  System Intervals (seconds)  =======================================
# This section control how often the system performs certain actions during backtesting.
# Adjusting these intervals can help balance between realism and speed of backtesting.
CJSYS_ANALYSIS_INTERVAL       = 30       # seconds in real time
CJSYS_CHECK_FILL_INTERVAL     = 40       # seconds in real time
CJSYS_DISPLAY_TIME_INTERVAL   = 60       # seconds in real time
CJSYS_LLM_REPORT_INTERVAL     = 500000   # seconds in real time
CJSYS_PRICE_MONITOR_INTERVAL  = 60       # seconds in real time
# ===========================================================================================================


# ====================================  Technical Analysis Parameters  ======================================
# Bollinger Bands (BB) parameters
CJSYS_BB_MIN_WIDTH_PCT        = 0.01
CJSYS_BB_WINDOW_SIZE          = 20       # Bollinger Bands: 20-day window with 2 standard deviations
# ===========================================================================================================


# =========================================     Risk Management    ==========================================
CJSYS_RISK_MAX_POSITION_PCT   = 0.05
# ===========================================================================================================

# CURRENTLY UNAVAILABLE
#   These data are controlled by ArenaX broker-side server config,
#   and not yet expose interface for users to customize at runtime.
# =======================================   Backtest Configuration   ========================================
# backtest duration controls how many days of historical data to use for backtesting.
# CJSYS_BACKTEST_DURATION_DAYS  = 300

# playback speed controls how fast the time advances in virtual environment during backtesting.
# 3000x means 1 second in real time corresponds to 3000 seconds (50 minutes) in backtest time.
# Because CJTrade System would skip non-trading hours and weekends, 1-year backtest with 12000x playback speed
# would take around 7 minutes to complete.
#
# Supported playback speeds:
#   [0.5, 1.0, 2.0, 5.0, 10.0, 30.0, 60.0, 120.0, 600.0, 1200.0, 3000.0, 6000.0, 12000.0, 30000.0]
# CJSYS_BACKTEST_PLAYBACK_SPEED = 12000.0
# ===========================================================================================================
