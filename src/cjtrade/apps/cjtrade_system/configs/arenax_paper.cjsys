# ArenaX Broker - Paper Trading Mode Configuration
# Uses real broker price feed, but orders are simulated (paper trading).
# Requires a real broker account for price data.

# =========================================   General Configuration   =======================================
CJSYS_WATCH_LIST              =
# ===========================================================================================================


# =======================================   Backtest Configuration   ========================================
# paper mode always runs at 1x speed (real time).
CJSYS_BACKTEST_PLAYBACK_SPEED = 1.0

# Not applicable in paper mode (no exit condition based on duration).
# CJSYS_BACKTEST_DURATION_DAYS =

CJSYS_SKIP_NON_TRADING_HOURS = n
CJSYS_STATE_FILE = paper_account_state.json
# ===========================================================================================================


# ======================================  System Intervals (seconds)  =======================================
CJSYS_ANALYSIS_INTERVAL       = 60
CJSYS_CHECK_FILL_INTERVAL     = 30
CJSYS_DISPLAY_TIME_INTERVAL   = 40
CJSYS_LLM_REPORT_INTERVAL     = 14400  # 4 hours
CJSYS_PRICE_MONITOR_INTERVAL  = 60
# ===========================================================================================================


# ====================================  Technical Analysis Parameters  ======================================
CJSYS_BB_MIN_WIDTH_PCT        = 0.01
CJSYS_BB_WINDOW_SIZE          = 50
# ===========================================================================================================


# =========================================     Risk Management    ==========================================
CJSYS_RISK_MAX_POSITION_PCT   = 0.05
# ===========================================================================================================
